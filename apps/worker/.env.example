# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis (Upstash — same as backend)
REDIS_URL=rediss://default:password@upstash-endpoint.upstash.io:6380

# Google Drive API (same credentials as backend)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# FFmpeg — leave empty to use system FFmpeg or auto-download
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# Storage
STORAGE_TYPE=DRIVE # S3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=k-vault
