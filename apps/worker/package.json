{
  "name": "worker",
  "version": "0.0.1",
  "description": "Local transcode worker for k-vault streaming platform",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev:watch": "nodemon --watch src --ext ts --exec ts-node src/main.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "bullmq": "^5.0.0",
    "dotenv": "^17.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^148.0.0",
    "ioredis": "^5.6.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.18.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
